  <bpmn:collaboration id="Collaboration_0rqsn8z">
    <bpmn:participant id="Participant_0lig83q" processRef="Process_16xamz1" />
    <bpmn:textAnnotation id="TextAnnotation_1geel0r">
      <bpmn:text>No operational context on who has contacted or customer status codes - stakeholder quote</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0lcyhpr">
      <bpmn:text>Reconciliation relies heavily on agents remembering and back tracking - Stakeholder quote</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1rr33qj">
      <bpmn:text>Leads to duplicate status checks, agents have no way of knowing whose already contacted a customer - operational observation</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_0e669n1">
      <bpmn:text>This has version conflict that as agents simultaneously edit it - stakeholder quote</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnnotation_1icr5xb">
      <bpmn:text>Some customers await call backs for months as dates are not recorded - operational observation</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Association_0i3r26w" associationDirection="None" sourceRef="Activity_147tkge" targetRef="TextAnnotation_1geel0r" />
    <bpmn:association id="Association_07u5dfm" associationDirection="None" sourceRef="Event_1a3p86k" targetRef="TextAnnotation_0lcyhpr" />
